# Server
DATABASE_URL="postgresql://finance:finance@localhost:5432/finance_tracking"
PORT=3000
API_KEY="dev-local-api-key"

# SEC EDGAR requires a descriptive User-Agent identifying the app and a contact.
# Requests without one are rejected with 403. See https://www.sec.gov/os/webmaster-faq#developers
EDGAR_USER_AGENT="finance-tracking contact@example.com"

# Expo push notifications (expo-server-sdk needs no extra key for Expo push service itself)
EXPO_ACCESS_TOKEN=""
